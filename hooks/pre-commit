#!/bin/bash

# Get the current commit hash
COMMIT_HASH=$(git rev-parse HEAD)
SHORT_HASH=$(git rev-parse --short HEAD)
BUILD_DATE=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

cat > frontend/src/version.ts << EOF
// This file is auto-generated by the pre-commit hook
// DO NOT EDIT MANUALLY

export const COMMIT_HASH = '$COMMIT_HASH';
export const SHORT_COMMIT_HASH = '$SHORT_HASH';
export const BUILD_DATE = '$BUILD_DATE';

export interface BuildInfo {
  commitHash: string;
  shortCommitHash: string;
  buildDate: string;
}

export const buildInfo: BuildInfo = {
  commitHash: COMMIT_HASH,
  shortCommitHash: SHORT_COMMIT_HASH,
  buildDate: BUILD_DATE,
};

export const getVersionString = (): string => SHORT_COMMIT_HASH;
EOF

git add frontend/src/version.ts

echo "Updated commit hash in frontend/src/version.ts"

cat > backend/src/version.ts << EOF
// This file is auto-generated by the pre-commit hook
// DO NOT EDIT MANUALLY

export const COMMIT_HASH = '$COMMIT_HASH';
export const SHORT_COMMIT_HASH = '$SHORT_HASH';
export const BUILD_DATE = '$BUILD_DATE';

export interface BuildInfo {
  commitHash: string;
  shortCommitHash: string;
  buildDate: string;
}

export const buildInfo: BuildInfo = {
  commitHash: COMMIT_HASH,
  shortCommitHash: SHORT_COMMIT_HASH,
  buildDate: BUILD_DATE,
};

export const getVersionString = (): string => SHORT_COMMIT_HASH;
EOF

git add backend/src/version.ts

echo "Updated commit hash in backend/src/version.ts"

exit 0